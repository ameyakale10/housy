# Copy this file to ".env" and fill in your values. Never commit .env.

# Which Gemini model Housy uses. Flash tier = cheap + low latency (good for chat).
# Options: gemini-2.5-flash | gemini-2.5-flash-lite | gemini-2.0-flash
HOUSY_MODEL=gemini-2.5-flash

# --- Provider mode ---------------------------------------------------------
# true  = Vertex AI  → bills against your Google Cloud credits (recommended; default)
# false = AI Studio  → uses GEMINI_API_KEY on a separate free quota
USE_VERTEX=true

# Vertex AI mode (USE_VERTEX=true):
#   1. Pick/create a GCP project on your billing account
#   2. Enable the Vertex AI API for it
#   3. Run: gcloud auth application-default login
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# AI Studio mode (only if USE_VERTEX=false) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- WhatsApp / Twilio (M2) ------------------------------------------------
# From the Twilio console (the WhatsApp sandbox works on a free trial).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# The public https URL Twilio posts to (your ngrok URL), e.g. https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Weekly nudge endpoint protection + message
NUDGE_TOKEN=change-me
NUDGE_TEXT=Hi! It's Housy 👋 Want to plan this week's meals and grocery list?
